{
  "manifest_version": 3,
  "name": "API URL Redirector",
  "version": "1.2.0",
  "description": "Intercept network requests and proxy them to an alternate URL, preserving all headers including Authorization.",
  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "service_worker.js",
    "type": "classic"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content_script.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["*://*/*"],
      "js": ["page_interceptor.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "128": "icon128.png"
  }
}